{
  "manifest_version": 3,
  "name": "Lecture Capture",
  "version": "1.0",
  "description": "Capture lecture slides from YouTube videos",
  "permissions": ["storage", "unlimitedStorage", "activeTab", "scripting"],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "manual-capture": {
      "suggested_key": {
        "default": "Alt+P",
        "mac": "Command+Shift+P"
      },
      "description": "Manually capture a single slide"
    }
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}
